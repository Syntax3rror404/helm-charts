{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "enabled": true
    },
    {
      "matchManagers": ["helm-values", "regex"],
      "bumpVersion": "patch"
    }
  ],
  "regexManagers": [
    {
      "fileMatch": ["Chart\\.yaml$"],
      "matchStrings": [
        "appVersion: \"?(?<currentValue>[^\"\\s]+)\"?\\s*# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(\\s+extractVersion=(?<extractVersion>\\S+))?"
      ],
      "datasourceTemplate": "{{datasource}}"
    }
  ]
}
